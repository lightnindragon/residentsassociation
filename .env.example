# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.
# These variables are server-only (API routes, Server Components, middleware); they are not exposed to the browser.

# Neon Postgres – https://neon.tech
DATABASE_URL="postgresql://[user]:[password]@[neon_hostname]/[dbname]?sslmode=require"

# NextAuth – generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret"
NEXTAUTH_URL="http://localhost:3000"

# Encrypt SMTP password in DB – long random string (same generator as NEXTAUTH_SECRET is fine)
ENCRYPTION_KEY="your-encryption-key"

# Vercel Blob – server uploads (gallery, committee photos). Store must allow public files for those URLs.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Optional: after `npm run upload-site-logo`, set this so the header uses Blob instead of /branding/site-logo.jpeg
# NEXT_PUBLIC_SITE_LOGO_URL="https://….public.blob.vercel-storage.com/site/main-logo.jpeg"
